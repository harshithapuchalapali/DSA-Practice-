input =[0,0,1,1,1,2,2,3,3,4]
Output = [0,1,2,3,4]

solution:
def duplicates(nums):
slow = 0
    for fast in range(1, len(nums)):
        if nums[fast] != nums[slow]:
            slow += 1
            nums[slow] = nums[fast]
    return slow + 1
nums=list(map(int,input().split()))
print(duplicates(nums))
