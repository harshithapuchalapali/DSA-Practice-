solution:

def two_sums(nums,target):
  left = 0
  right = len(nums) - 1
  
  while left < right:
      s = nums[left] + nums[right]
  
      if s == target:
          return [left, right]
  
      elif s < target:
          left += 1
  
      else:
          right -= 1
nums = [1,2,4,6,8]
target = 10
print(two_sums(nums,target))
